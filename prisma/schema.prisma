// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------
// ZONE SÉCURISÉE (COFFRE-FORT NUMÉRIQUE)
// Dans une architecture cible, cette table serait dans une base de données isolée
// ------------------------------------------------------

model PractitionerProfile {
  id             String   @id @default(uuid())
  practitionerId String   @unique // Supabase Auth User ID
  firstName      String
  lastName       String
  title          String?  // e.g. Masseur-Kinésithérapeute
  inamiNumber    String?
  address        String?
  phone          String?
  email          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PatientVault {
  id             String          @id @default(uuid())
  practitionerId String          @default("kine2024") // Temporaire pour la migration, on mettra l'UUID Supabase
  firstName      String
  lastName       String
  email          String          @unique
  dateOfBirth    DateTime?
  createdAt      DateTime        @default(now())
  
  // Le lien vers le dossier clinique se fait uniquement via cet ID cryptographique
  clinicalRecord ClinicalRecord?
}

// ------------------------------------------------------
// ZONE CLINIQUE (PSEUDONYMISÉE)
// Aucune information personnelle (IPI) ne réside ici.
// ------------------------------------------------------
model ClinicalRecord {
  id           String        @id @default(uuid())
  patient      PatientVault  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId    String        @unique
  pathology    String?       // Optionnel: motif principal de consultation
  assessments  Assessment[]
  exercises    Exercise[]    // Nouveau: liste des exercices prescrits
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Exercise {
  id               String         @id @default(uuid())
  clinicalRecord   ClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)
  clinicalRecordId String
  name             String
  sets             String?
  reps             String?
  instructions     String?
  videoUrl         String?
  createdAt        DateTime       @default(now())
}

model Assessment {
  id             String                @id @default(uuid())
  recordId       String
  timelineAnchor String                // "T0_INITIAL", "T1_MID_TREATMENT", "T2_FINAL"
  timestamp      DateTime              @default(now())
  practitionerNotes String?
  
  record         ClinicalRecord        @relation(fields: [recordId], references: [id], onDelete: Cascade)
  questionnaires QuestionnaireResult[]
}

model QuestionnaireResult {
  id             String     @id @default(uuid())
  assessmentId   String
  type           String     // "TAMPA", "ODI", "START_BACK"
  score          Int
  maxScore       Int
  rawResponses   String     // JSON string pour stocker les détails des réponses
  completedAt    DateTime   @default(now())
  isPatientInput Boolean    @default(true)
  
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}
