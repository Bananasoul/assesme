# ----- Supabase (Auth + Postgres) -----
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ----- Prisma (Postgres direct) -----
# Dashboard → Project Settings → Database → Connection string
# URL = pooler (port 6543) — utilisé en runtime
# DIRECT_URL = direct connection (port 5432) — utilisé pour les migrations
DATABASE_URL=postgres://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgres://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
